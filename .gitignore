# ============================================================
# JOBRADAR .GITIGNORE - MONOREPO
# ============================================================

# ============================================================
# VIRTUAL ENVIRONMENT (CRITICAL)
# ============================================================
venv/
venv_*/
.venv/
env/
.env/
venv_wsl/
__pycache__/

# ============================================================
# BACKEND
# ============================================================

# Python virtual environment
backend/venv/
backend/venv_*/
backend/.venv/
backend/env/
backend/.env/
backend/venv_wsl/

# Python cache
backend/__pycache__/
backend/*/__pycache__/
backend/*/*/__pycache__/
backend/*/*/*/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.pyd
backend/.pytest_cache/
backend/.mypy_cache/
backend/.ruff_cache/

# Python build artifacts
backend/build/
backend/dist/
backend/*.egg-info/
backend/*.egg
backend/pip-log.txt
backend/pip-delete-this-directory.txt

# Database migrations (keep the migration files, but not the generated ones)
backend/migrations/__pycache__/
backend/migrations/*.pyc

# Logs
backend/logs/
backend/*.log
backend/*.log.*

# Environment files
backend/.env
backend/.env.local
backend/.env.*.local
backend/.flaskenv

# IDEs
backend/.vscode/
backend/.idea/
backend/*.iml
backend/.DS_Store
backend/Thumbs.db

# Testing
backend/.coverage
backend/htmlcov/
backend/.pytest_cache/
backend/.tox/
backend/.nox/
backend/coverage.xml
backend/*.cover

# Package management
backend/poetry.lock
backend/pip-wheel-metadata/
backend/share/python-wheels/
backend/lib64/
backend/parts/
backend/sdist/
backend/var/
backend/wheelhouse/
backend/develop-eggs/
backend/eggs/
backend/.eggs/

# SQLite (if used)
backend/*.db
backend/*.sqlite
backend/*.sqlite3

# Docker
backend/.dockerignore

# Temporary files
backend/tmp/
backend/temp/
backend/*.tmp
backend/*.swp
backend/*.swo
backend/*~

# Certificates (keep ca.pem for deployment, ignore others)
backend/certs/*.pem
backend/certs/*.cert
backend/certs/*.key
!backend/certs/ca.pem


